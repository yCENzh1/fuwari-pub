---
import { Font } from 'astro:assets';
import ConfigCarrier from "@components/ConfigCarrier.astro";
import Lightbox from "../components/lightbox.astro";
import { profileConfig, siteConfig } from "@/config";
import {
	AUTO_MODE,
	BANNER_HEIGHT,
	BANNER_HEIGHT_EXTEND,
	BANNER_HEIGHT_HOME,
	DARK_MODE,
	DEFAULT_THEME,
	LIGHT_MODE,
	PAGE_WIDTH,
} from "../constants/constants";
import { defaultFavicons } from "../constants/icon";
import type { Favicon } from "../types/config";
import { pathsEqual, url } from "../utils/url-utils";
import "katex/dist/katex.css";
import { getCollection } from "astro:content";
import "../styles/main.css";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	setOGTypeArticle?: boolean;
	lang?: string;
}

const { title, description, setOGTypeArticle, lang } = Astro.props;
let { banner } = Astro.props;

const isHomePage = pathsEqual(Astro.url.pathname, url("/"));
const configHue = siteConfig.themeColor.hue;
const enableBanner = siteConfig.banner.enable;

if (!banner || typeof banner !== "string" || banner.trim() === "") {
	banner = siteConfig.banner.src;
}

// 文章数据（用于 OG 标签）
const urlPath = Astro.url.pathname.replace(/^\/posts\//, "").replace(/\/$/, "");
let pageData: {
	title?: string;
	published?: Date;
	updated?: Date;
	tags?: string[];
	image?: string;
} = {};

if (urlPath && !urlPath.includes("/")) {
	try {
		const allEntries = await getCollection("posts");
		const entry = allEntries.find((e) => e.id === urlPath);
		if (entry) {
			pageData = {
				title: entry.data.title,
				published: entry.data.published,
				updated: entry.data.updated,
				tags: entry.data.tags,
				image: entry.data.image,
			};
		}
	} catch {
		// 不是文章页面，忽略
	}
}

const formatDate = (date: Date | string | undefined): string | null => {
	if (!date) return null;
	if (date instanceof Date) {
		return date.toISOString().split('T')[0];
	}
	if (typeof date === 'string') {
		return date.split('T')[0];
	}
	return null;
};

const publishedDate = formatDate(pageData.published);
const updatedDate = formatDate(pageData.updated);
const articleTags: string[] = pageData.tags || [];

const pageTitle = title
	? `${title} - ${siteConfig.title}`
	: `${siteConfig.title} - ${siteConfig.subtitle}`;

const favicons: Favicon[] =
	siteConfig.favicon.length > 0 ? siteConfig.favicon : defaultFavicons;

const siteLang = lang ?? "zh-CN";

const bannerOffsetByPosition: Record<string, string> = {
	top: `${BANNER_HEIGHT_EXTEND}vh`,
	center: `${BANNER_HEIGHT_EXTEND / 2}vh`,
	bottom: "0",
};
const bannerOffset = bannerOffsetByPosition[siteConfig.banner.position ?? "center"];
---

<!DOCTYPE html>
<html lang={siteLang} class="bg-(--page-bg) transition text-[14px] md:text-[16px]"
	  data-overlayscrollbars-initialize
>
	<head>
		<Font cssVariable="--font-roboto" />
		<Font cssVariable="--font-jetbrains-mono" />

		<!-- Preload critical resources for LCP optimization -->
		{enableBanner && banner && (
			<link rel="preload" as="image" href={banner.startsWith('/') ? url(banner) : banner} fetchpriority="high" />
		)}

		<script is:inline define:vars={{DEFAULT_THEME, LIGHT_MODE, DARK_MODE, AUTO_MODE, configHue}}>
		(function() {
			const theme = localStorage.getItem('theme') || DEFAULT_THEME;
			const isDark = theme === DARK_MODE || 
				(theme === AUTO_MODE && window.matchMedia('(prefers-color-scheme: dark)').matches);
			document.documentElement.classList.toggle('dark', isDark);
			
			document.documentElement.style.setProperty('--hue', localStorage.getItem('hue') || configHue);
		})();
		</script>

		<script is:inline type="text/javascript">
			(function(c,l,a,r,i,t,y){
				c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
				t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
				y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
			})(window, document, "clarity", "script", "tajp0d55h4");
		</script>

		<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-D8YKHXY480"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){window.dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-D8YKHXY480');
		</script>

		<script is:inline defer src="https://cloud.umami.is/script.js" data-website-id="a1a1f897-326f-4e68-a6f0-54e9dc361522"></script>

		<title>{pageTitle}</title>

		<meta charset="UTF-8" />
		<meta name="description" content={description || pageTitle}>
		<meta name="author" content={profileConfig.name}>

		<meta property="og:site_name" content={siteConfig.title}>
		<meta property="og:url" content={Astro.url}>
		<meta property="og:title" content={pageTitle}>
		<meta property="og:description" content={description || pageTitle}>
		<meta property="og:type" content={setOGTypeArticle ? "article" : "website"} />
		<meta property="og:image" content={banner?.startsWith('http') ? banner : banner?.startsWith('/') ? new URL(banner, Astro.site).toString() : siteConfig.banner.src.startsWith('http') ? siteConfig.banner.src : siteConfig.banner.src.startsWith('/') ? new URL(siteConfig.banner.src, Astro.site).toString() : siteConfig.banner.src} data-swup-keep>
		{publishedDate && <meta property="article:published_time" content={publishedDate}>}
		{updatedDate && <meta property="article:modified_time" content={updatedDate}>}
		{articleTags.map(tag => <meta property="article:tag" content={tag}>)}

		<link rel="canonical" href={Astro.url}>

		<link rel="dns-prefetch" href="https://api.iconify.design">
		<link rel="preconnect" href="https://api.iconify.design" crossorigin>

		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		{favicons.map(favicon => (
			<link rel="icon"
				  href={favicon.src.startsWith('/') ? url(favicon.src) : favicon.src}
				  sizes={favicon.sizes}
				  media={favicon.theme && `(prefers-color-scheme: ${favicon.theme})`}
			/>
		))}

		<style define:vars={{
			configHue,
			'page-width': `clamp(${PAGE_WIDTH}rem, 75vw, 140rem)`,
		}}></style>

		<slot name="head"></slot>

		<link rel="alternate" type="application/rss+xml" title={profileConfig.name} href={`${Astro.site}rss.xml`}/>
	</head>
	<body class="min-h-screen transition" class:list={[{"lg:is-home": isHomePage, "enable-banner": enableBanner}]}>
		<ConfigCarrier></ConfigCarrier>
		<div id="swup-progress-bar" class="swup-progress-bar"></div>
		<slot />
		<Lightbox />
		<div id="page-height-extend" class="hidden h-[300vh]"></div>
	</body>
</html>

<style is:global define:vars={{
	bannerOffset,
	'banner-height-home': `${BANNER_HEIGHT_HOME}vh`,
	'banner-height': `${BANNER_HEIGHT}vh`,
	'banner-height-extend': `${BANNER_HEIGHT_EXTEND}vh`,
}}>
/* Swup navigation progress bar */
.swup-progress-bar {
	--progress-height: 3px;
	--progress-duration: 8s;
	--progress-hue-start: -30deg;
	--progress-hue-end: 15deg;
	--progress-glow: 0 0 8px oklch(0.7 0.15 var(--hue) / 0.6);

	position: fixed;
	top: 0;
	left: 0;
	height: var(--progress-height);
	background: var(--primary);
	z-index: 9999;
	pointer-events: none;
	width: 0;
	opacity: 0;
}
.swup-progress-bar.is-loading {
	opacity: 1;
	animation: swup-progress var(--progress-duration) cubic-bezier(0.2, 0.5, 0, 1) forwards;
	box-shadow: var(--progress-glow);
}
.swup-progress-bar.is-finishing {
	opacity: 1;
	width: 100% !important;
	animation: none;
	filter: hue-rotate(var(--progress-hue-end));
	transition: width 0.2s ease-out;
}
.swup-progress-bar.is-done {
	width: 100%;
	opacity: 0;
	animation: none;
	filter: hue-rotate(var(--progress-hue-end));
	transition: opacity 0.3s ease;
}
@keyframes swup-progress {
	0% { width: 0; filter: hue-rotate(var(--progress-hue-start)); }
	20% { width: 30%; }
	50% { width: 60%; }
	80% { width: 80%; }
	100% { width: 95%; filter: hue-rotate(var(--progress-hue-end)); }
}

@reference 'tailwindcss';
@layer components {
	.enable-banner #banner-wrapper {
		@apply h-(--banner-height-home)
	}
	.enable-banner #banner {
		@apply h-(--banner-height-home) translate-y-(--bannerOffset)
	}
	.enable-banner #top-row {
		@apply h-[calc(var(--banner-height-home)-4.5rem)] transition-all duration-300
	}
	@media (min-width: 1024px) {
		.enable-banner.lg\:is-home #banner-wrapper {
			@apply h-(--banner-height-home) translate-y-(--banner-height-extend)
		}
		.enable-banner.lg\:is-home #banner {
			@apply h-(--banner-height-home) translate-y-0
		}
		.enable-banner.lg\:is-home #main-grid {
			@apply translate-y-[var(--banner-height-extend)];
		}
		.enable-banner.lg\:is-home #sidebar-sticky {
			@apply top-[calc(1rem-var(--banner-height-extend))]
		}
	}
	.navbar-hidden {
		@apply opacity-0 -translate-y-16
	}
}
</style>

<script>
import '../utils/preload-icons';
import { OverlayScrollbars } from 'overlayscrollbars';
import { getHue, getStoredTheme, setHue, setTheme } from "../utils/setting-utils";
import { pathsEqual, url } from "../utils/url-utils";
import {
	BANNER_HEIGHT,
	BANNER_HEIGHT_HOME,
	BANNER_HEIGHT_EXTEND,
	MAIN_PANEL_OVERLAPS_BANNER_HEIGHT
} from "../constants/constants";
import { siteConfig } from '../config';

const NAVBAR_HEIGHT = 72;
let scrollTicking = false;
let imageObserver: MutationObserver | null = null;
let clickOutsideCleanups: Array<() => void> = [];
let scrollCleanup: (() => void) | null = null;

// 缓存常用 DOM 元素引用
let domRefs: {
	backToTopBtn: HTMLElement | null;
	tocWrapper: HTMLElement | null;
	navbarWrapper: HTMLElement | null;
	banner: HTMLElement | null;
	pageHeightExtend: HTMLElement | null;
	progressBar: HTMLElement | null;
} | null = null;

function getDomRefs() {
	if (!domRefs) {
		domRefs = {
			backToTopBtn: document.getElementById('back-to-top-btn'),
			tocWrapper: document.getElementById('toc-wrapper'),
			navbarWrapper: document.getElementById('navbar-wrapper'),
			banner: document.getElementById('banner'),
			pageHeightExtend: document.getElementById('page-height-extend'),
			progressBar: document.getElementById('swup-progress-bar'),
		};
	}
	return domRefs;
}

function clearDomRefs() {
	domRefs = null;
}

function getScrollTop(): number {
	return document.documentElement.scrollTop || document.body.scrollTop;
}

function getBannerThreshold(forNavbar = false): number {
	const isHome = document.body.classList.contains('lg:is-home') && window.innerWidth >= 1024;
	const heightPercent = isHome ? BANNER_HEIGHT_HOME : BANNER_HEIGHT;
	const bannerPx = window.innerHeight * (heightPercent / 100);

	if (forNavbar) {
		return bannerPx - NAVBAR_HEIGHT - (MAIN_PANEL_OVERLAPS_BANNER_HEIGHT * 16) - 16;
	}
	return bannerPx;
}

function isBannerEnabled(): boolean {
	return !!document.getElementById('banner-wrapper');
}

function setupClickOutside(panel: string, ignores: string[]): () => void {
	const handler = (event: MouseEvent) => {
		const panelDom = document.getElementById(panel);
		const target = event.target;
		if (!(target instanceof Node)) return;

		for (const ig of ignores) {
			const el = document.getElementById(ig);
			if (el === target || el?.contains(target)) return;
		}
		panelDom?.classList.add("float-panel-closed");
	};

	document.addEventListener("click", handler, true);
	return () => document.removeEventListener("click", handler, true);
}

function cleanupAllClickOutsideHandlers() {
	for (const cleanup of clickOutsideCleanups) {
		cleanup();
	}
	clickOutsideCleanups = [];
}

function initOverlayScrollbarsOnce() {
	const body = document.body;
	if (body.hasAttribute('data-scrollbar-initialized')) return;
	OverlayScrollbars(
		{ target: body, cancel: { nativeScrollbarsOverlaid: true } },
		{ scrollbars: { theme: 'scrollbar-base scrollbar-auto py-1', autoHide: 'move', autoHideDelay: 500 } }
	);
	body.setAttribute('data-scrollbar-initialized', 'true');
}

function initKatexScrollbars() {
	const elements = document.querySelectorAll('.katex-display:not([data-scrollbar-initialized])');
	if (elements.length === 0) return;

	const observer = new IntersectionObserver((entries, obs) => {
		for (const entry of entries) {
			if (!entry.isIntersecting) continue;
			const el = entry.target;
			if (!el.parentNode || el.hasAttribute('data-scrollbar-initialized')) continue;

			const container = document.createElement('div');
			container.className = 'katex-display-container';
			container.setAttribute('aria-label', 'scrollable container for formulas');
			el.parentNode.insertBefore(container, el);
			container.appendChild(el);

			OverlayScrollbars(container, {
				scrollbars: { theme: 'scrollbar-base scrollbar-auto', autoHide: 'leave', autoHideDelay: 500 }
			});
			el.setAttribute('data-scrollbar-initialized', 'true');
			obs.unobserve(el);
		}
	}, { rootMargin: '100px', threshold: 0.1 });

	elements.forEach(el => observer.observe(el));
}

function initImageLoading() {
	const wrappers = document.querySelectorAll('[data-image-wrapper]');
	wrappers.forEach(wrapper => {
		const img = wrapper.querySelector('[data-image-element]') as HTMLImageElement | null;
		const loadingBar = wrapper.querySelector('.loading-bar');
		if (!img || !loadingBar) return;

		const markLoaded = () => {
			img.classList.add('loaded');
			setTimeout(() => loadingBar.classList.add('hide'), 300);
		};

		if (img.complete && img.naturalHeight !== 0) {
			img.classList.add('loaded');
			loadingBar.classList.add('hide');
			return;
		}

		img.addEventListener('load', markLoaded, { once: true });
		img.addEventListener('error', markLoaded, { once: true });
	});
}

function setupImageObserverOnce() {
	if (imageObserver) return;
	if (document.querySelectorAll('[data-image-wrapper]').length === 0) return;

	imageObserver = new MutationObserver(mutations => {
		for (const m of mutations) {
			for (const node of m.addedNodes) {
				if (node.nodeType === 1) {
					const el = node as Element;
					if (el.matches?.('[data-image-wrapper]') || el.querySelector?.('[data-image-wrapper]')) {
						initImageLoading();
						return;
					}
				}
			}
		}
	});

	imageObserver.observe(document.body, { childList: true, subtree: true });
}

function showBanner() {
	if (!siteConfig.banner.enable) return;
	getDomRefs().banner?.classList.remove('opacity-0', 'scale-105');
}

// Swup 导航时移除动画类，避免重复播放
const stripOnloadAnimations = () => {
	let animationsDone = false;
	try {
		animationsDone = sessionStorage.getItem('onloadAnimationsDone') === '1';
	} catch {}

	const animated = document.querySelectorAll('.onload-animation');
	if (animationsDone) {
		animated.forEach(el => el instanceof HTMLElement && el.classList.remove('onload-animation'));
		return;
	}

	let finalized = false;
	const finalize = () => {
		if (finalized) return;
		finalized = true;
		try { sessionStorage.setItem('onloadAnimationsDone', '1'); } catch {}
		animated.forEach(el => el instanceof HTMLElement && el.classList.remove('onload-animation'));
	};

	animated.forEach(el => {
		if (!(el instanceof HTMLElement)) return;
		el.addEventListener('animationend', finalize, { once: true });
		const computed = window.getComputedStyle(el);
		if (computed.animationDuration === '0s' || computed.animationName === 'none') finalize();
	});
};

function handleScroll() {
	const scrollTop = getScrollTop();
	const bannerHeight = getBannerThreshold();
	const navbarThreshold = getBannerThreshold(true);
	const refs = getDomRefs();

	refs.backToTopBtn?.classList.toggle('hide', scrollTop <= bannerHeight);

	if (isBannerEnabled()) {
		refs.tocWrapper?.classList.toggle('toc-hide', scrollTop <= bannerHeight);
		refs.navbarWrapper?.classList.toggle('navbar-hidden', scrollTop >= navbarThreshold);
	}
}

function onScroll() {
	if (scrollTicking) return;
	scrollTicking = true;
	requestAnimationFrame(() => {
		handleScroll();
		scrollTicking = false;
	});
}

function initPage() {
	const run = () => {
		initKatexScrollbars();
		initImageLoading();
	};

	if ('requestIdleCallback' in window) {
		requestIdleCallback(run, { timeout: 200 });
	} else {
		setTimeout(run, 0);
	}

	showBanner();
	stripOnloadAnimations();
}

function setupSwupHooksOnce() {
	if (!window.swup) return;

	window.swup.hooks.on('link:click', () => {
		document.documentElement.style.setProperty('--content-delay', '0ms');
		if (!isBannerEnabled()) return;

		const { navbarWrapper } = getDomRefs();
		if (navbarWrapper && document.body.classList.contains('lg:is-home') && getScrollTop() >= getBannerThreshold(true)) {
			navbarWrapper.classList.add('navbar-hidden');
		}
	});

	window.swup.hooks.on('page:view', () => {
		initPage();
		const refs = getDomRefs();
		refs.pageHeightExtend?.classList.remove('hidden');
		refs.tocWrapper?.classList.remove('toc-not-ready');
	});

	window.swup.hooks.on('visit:start', (visit: { to: { url: string } }) => {
		const isHome = pathsEqual(visit.to.url, url('/'));
		document.body.classList.toggle('lg:is-home', isHome);

		// 清除缓存，Swup 会替换 DOM 元素
		clearDomRefs();
		const refs = getDomRefs();
		refs.pageHeightExtend?.classList.remove('hidden');
		refs.tocWrapper?.classList.add('toc-not-ready');

		const bar = refs.progressBar;
		if (bar) {
			bar.classList.remove('is-loading', 'is-finishing', 'is-done');
			bar.style.width = '0';
			void bar.offsetWidth;
			bar.classList.add('is-loading');
		}
	});

	window.swup.hooks.on('visit:end', () => {
		const refs = getDomRefs();
		setTimeout(() => refs.pageHeightExtend?.classList.add('hidden'), 200);

		const bar = refs.progressBar;
		if (bar) {
			bar.classList.remove('is-loading');
			bar.classList.add('is-finishing');
			setTimeout(() => {
				bar.classList.remove('is-finishing');
				bar.classList.add('is-done');
			}, 250);
		}
	});
}

function setupGlobalListenersOnce() {
	cleanupAllClickOutsideHandlers();
	clickOutsideCleanups.push(setupClickOutside("display-setting", ["display-setting", "display-settings-switch"]));
	clickOutsideCleanups.push(setupClickOutside("nav-menu-panel", ["nav-menu-panel", "nav-menu-switch"]));
	clickOutsideCleanups.push(setupClickOutside("search-panel", ["search-panel", "search-bar", "search-switch"]));

	if (scrollCleanup) scrollCleanup();
	window.addEventListener('scroll', onScroll, { passive: true });
	scrollCleanup = () => window.removeEventListener('scroll', onScroll);
}

function main() {
	setTheme(getStoredTheme());
	setHue(getHue());

	initOverlayScrollbarsOnce();
	setupGlobalListenersOnce();
	setupSwupHooksOnce();
	setupImageObserverOnce();
	initPage();
}

if (window.swup) {
	main();
} else {
	document.addEventListener('swup:enable', main);
}
</script>